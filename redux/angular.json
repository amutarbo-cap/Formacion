{
  "$schema": "https://angular.io/config/schema.json",
  "version": 1,
  "projects": {
    "redux-exercise-template": {
      "projectType": "application",
      "root": "",
      "sourceRoot": "src",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath": "dist/redux-exercise-template",
            "index": "src/index.html",
            "main": "src/main.ts",
            "polyfills": [],
            "tsConfig": "tsconfig.app.json",
            "assets": ["src/favicon.ico"],
            "styles": [],
            "scripts": []
          }
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "options": {
            "browserTarget": "redux-exercise-template:build"
          }
        }
      }
    }
  },
  "defaultProject": "redux-exercise-template",
  "cli": {
    "analytics": false
  }
}
